generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  COUNSELOR
  PROVIDER
  ADMIN
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum ScholarshipStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  firstName     String?
  lastName      String?
  image         String?
  password      String?
  role          Role      @default(STUDENT)
  bio           String?
  phone         String?
  location      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profile      StudentProfile?
  applications Application[]
  documents    Document[]

  students  CounselorStudent[] @relation("CounselorStudents")
  counselor CounselorStudent[] @relation("StudentCounselor")

  scholarships  Scholarship[]
  notifications Notification[]
  sessions      Session[]
  accounts      Account[]

  @@map("users")
}

model StudentProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gpa               Float?
  graduationYear    Int?
  major             String?
  university        String?
  highSchool        String?
  state             String?
  country           String   @default("Indonesia")
  ethnicity         String?
  financialNeed     Boolean  @default(false)
  firstGenStudent   Boolean  @default(false)
  militaryAffiliate Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("student_profiles")
}

model Scholarship {
  id              String            @id @default(cuid())
  providerId      String
  provider        User              @relation(fields: [providerId], references: [id], onDelete: Cascade)
  title           String
  description     String            @db.Text
  amount          Float
  currency        String            @default("IDR")
  deadline        DateTime
  status          ScholarshipStatus @default(DRAFT)
  category        String[]
  requirements    String[]
  minGpa          Float?
  maxApplicants   Int?
  totalApplicants Int               @default(0)
  country         String?
  university      String?
  major           String[]
  imageUrl        String?
  applicationUrl  String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  applications Application[]

  @@map("scholarships")
}

model Application {
  id            String            @id @default(cuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  scholarshipId String
  scholarship   Scholarship       @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)
  status        ApplicationStatus @default(DRAFT)
  essay         String?           @db.Text
  notes         String?           @db.Text
  submittedAt   DateTime?
  reviewedAt    DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  documents ApplicationDocument[]

  @@unique([userId, scholarshipId])
  @@map("applications")
}

model Document {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  type      String
  url       String
  size      Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applicationDocs ApplicationDocument[]

  @@map("documents")
}

model ApplicationDocument {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  documentId    String
  document      Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([applicationId, documentId])
  @@map("application_documents")
}

model CounselorStudent {
  id          String   @id @default(cuid())
  counselorId String
  counselor   User     @relation("CounselorStudents", fields: [counselorId], references: [id], onDelete: Cascade)
  studentId   String
  student     User     @relation("StudentCounselor", fields: [studentId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([counselorId, studentId])
  @@map("counselor_students")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@map("notifications")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime

  @@map("sessions")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  @@unique([provider, providerAccountId])
  @@map("accounts")
}